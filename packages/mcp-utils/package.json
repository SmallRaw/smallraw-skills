{
  "name": "mcp-client-utils",
  "version": "0.1.1",
  "description": "Lazy MCP client CLI — connect, call, disconnect on demand via registry",
  "bin": {
    "mcp-client-utils": "dist/mcp-utils.js"
  },
  "files": [
    "dist/mcp-utils.js",
    "mcp-registry.schema.json"
  ],
  "scripts": {
    "build": "esbuild src/index.ts --bundle --platform=node --target=node18 --format=cjs --outfile=dist/mcp-utils.js --banner:js='#!/usr/bin/env node'",
    "prepack": "npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0"
  },
  "devDependencies": {
    "@types/node": "^25.3.5",
    "esbuild": "^0.25.12",
    "typescript": "^5.7.0"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "cli"
  ],
  "license": "MIT"
}
